rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Device / system collections ──

    match /heartbeats/{deviceId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /device_status/{deviceId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /motions/{motionId} {
      allow read, write: if true;
    }
    match /image_diffs/{diffId} {
      allow read, write: if true;
    }
    // Wallcam pipeline (#765/#823/#794): the recorder reads AND writes these
    // unauthenticated via the Firestore REST API (it has no credentials), so
    // both stay open — gating reads behind auth caused a past 403 that silently
    // stopped recordings (see test_wallcam_rules.py). The Clips view reads them
    // as a signed-in user, which `if true` already allows.
    match /wallcam_recording_plan/{planId} {
      allow read, write: if true;
    }
    match /wallcam_recordings/{recId} {
      allow read, write: if true;
    }
    match /calendly_bookings/{docId} {
      allow read, write: if false;
    }
    match /palmr_waitlist/{docId} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() < 255;
      allow read, update, delete: if false;
    }
    // Palmr pre-orders: public can submit, only admin can read/modify
    match /palmr_preorders/{docId} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() < 255
                    && request.resource.data.name is string
                    && request.resource.data.business_name is string;
      allow read, update, delete: if false;
    }

    // ── Commander (Emma) ──

    match /commander_tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_tasks/{taskId}/output/{chunkId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_tasks/{taskId}/chat/{msgId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_workers/{workerId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_pomodoro/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    // Allowlist gating the emma UI. Reads must be allowed for authenticated
    // users — the UI looks up `<emailToDocId>` to decide whether to grant
    // access. Writes are gated client-side (admin panel) and by the seed
    // function in AuthContext.jsx; rules just require auth. Without these
    // rules Firestore denies the lookup and every login → access denied.
    match /commander_allowed_users/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_user_projects/{uid} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_activity/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_inbox_requests/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_inbox_requests/{docId}/input/{chunkId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_notes/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_project_tags/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_repo_registry/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_user_drive/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /commander_user_drive_pending/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    // collectionGroup('chat') needs a /{path=**}/chat/... wildcard rule —
    // the per-task path rule above doesn't match collectionGroup queries.
    match /{path=**}/chat/{msgId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // ── Auto-Funding rules ──
    // Authenticated users can create requests and read their own.
    // Worker (admin SDK) writes status/output — bypasses rules.
    match /auto_funding_requests/{requestId} {
      allow create: if request.auth != null
                    && request.resource.data.requested_by_uid == request.auth.uid;
      allow read: if request.auth != null
                  && resource.data.requested_by_uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // ── Palmr Vertical Apps ──
    // Each app uses a unique collection prefix so data stays
    // isolated. All require Google sign-in (request.auth != null).
    // ══════════════════════════════════════════════════════

    // ── PMS (Short-Term Rental) — prefix: pms_ ──
    match /pms_properties/{docId} { allow read, write: if request.auth != null; }
    match /pms_reservations/{docId} { allow read, write: if request.auth != null; }
    match /pms_tasks/{docId} { allow read, write: if request.auth != null; }

    // ── Gym — unprefixed (legacy) ──
    match /members/{docId} { allow read, write: if request.auth != null; }
    match /classes/{docId} { allow read, write: if request.auth != null; }
    match /checkins/{docId} { allow read, write: if request.auth != null; }
    match /equipment/{docId} { allow read, write: if request.auth != null; }
    match /signals/{docId} { allow read, write: if request.auth != null; }

    // ── Storage — prefix: storage_ ──
    match /storage_units/{docId} { allow read, write: if request.auth != null; }
    match /storage_tenants/{docId} { allow read, write: if request.auth != null; }
    match /storage_access/{docId} { allow read, write: if request.auth != null; }
    match /storage_maintenance/{docId} { allow read, write: if request.auth != null; }
    match /storage_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Clean (Commercial Cleaning) — prefix: clean_ ──
    match /clean_clients/{docId} { allow read, write: if request.auth != null; }
    match /clean_jobs/{docId} { allow read, write: if request.auth != null; }
    match /clean_inspections/{docId} { allow read, write: if request.auth != null; }
    match /clean_teams/{docId} { allow read, write: if request.auth != null; }
    match /clean_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Resto (Restaurants & QSR) — prefix: resto_ ──
    match /resto_locations/{docId} { allow read, write: if request.auth != null; }
    match /resto_staff/{docId} { allow read, write: if request.auth != null; }
    match /resto_checklists/{docId} { allow read, write: if request.auth != null; }
    match /resto_inspections/{docId} { allow read, write: if request.auth != null; }
    match /resto_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Senior (Senior Living) — prefix: senior_ ──
    match /senior_residents/{docId} { allow read, write: if request.auth != null; }
    match /senior_staff/{docId} { allow read, write: if request.auth != null; }
    match /senior_rounds/{docId} { allow read, write: if request.auth != null; }
    match /senior_incidents/{docId} { allow read, write: if request.auth != null; }
    match /senior_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Retail (SMB Retail) — prefix: retail_ ──
    match /retail_stores/{docId} { allow read, write: if request.auth != null; }
    match /retail_inventory/{docId} { allow read, write: if request.auth != null; }
    match /retail_checklists/{docId} { allow read, write: if request.auth != null; }
    match /retail_incidents/{docId} { allow read, write: if request.auth != null; }
    match /retail_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Cowork (Co-Working Spaces) — prefix: cowork_ ──
    match /cowork_spaces/{docId} { allow read, write: if request.auth != null; }
    match /cowork_members/{docId} { allow read, write: if request.auth != null; }
    match /cowork_bookings/{docId} { allow read, write: if request.auth != null; }
    match /cowork_inspections/{docId} { allow read, write: if request.auth != null; }
    match /cowork_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Hotel (Small Hotels) — prefix: hotel_ ──
    match /hotel_rooms/{docId} { allow read, write: if request.auth != null; }
    match /hotel_guests/{docId} { allow read, write: if request.auth != null; }
    match /hotel_housekeeping/{docId} { allow read, write: if request.auth != null; }
    match /hotel_patrols/{docId} { allow read, write: if request.auth != null; }
    match /hotel_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Canna (Cannabis) — prefix: canna_ ──
    match /canna_facilities/{docId} { allow read, write: if request.auth != null; }
    match /canna_inventory/{docId} { allow read, write: if request.auth != null; }
    match /canna_environment/{docId} { allow read, write: if request.auth != null; }
    match /canna_compliance/{docId} { allow read, write: if request.auth != null; }
    match /canna_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Salon (Salons & Spas) — prefix: salon_ ──
    match /salon_stations/{docId} { allow read, write: if request.auth != null; }
    match /salon_staff/{docId} { allow read, write: if request.auth != null; }
    match /salon_appointments/{docId} { allow read, write: if request.auth != null; }
    match /salon_inspections/{docId} { allow read, write: if request.auth != null; }
    match /salon_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Vet (Veterinary & Pet Boarding) — prefix: vet_ ──
    match /vet_animals/{docId} { allow read, write: if request.auth != null; }
    match /vet_kennels/{docId} { allow read, write: if request.auth != null; }
    match /vet_patrols/{docId} { allow read, write: if request.auth != null; }
    match /vet_wellness/{docId} { allow read, write: if request.auth != null; }
    match /vet_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Venue (Event Venues) — prefix: venue_ ──
    match /venue_spaces/{docId} { allow read, write: if request.auth != null; }
    match /venue_events/{docId} { allow read, write: if request.auth != null; }
    match /venue_inspections/{docId} { allow read, write: if request.auth != null; }
    match /venue_damages/{docId} { allow read, write: if request.auth != null; }
    match /venue_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Wash (Car Washes) — prefix: wash_ ──
    match /wash_bays/{docId} { allow read, write: if request.auth != null; }
    match /wash_equipment/{docId} { allow read, write: if request.auth != null; }
    match /wash_inspections/{docId} { allow read, write: if request.auth != null; }
    match /wash_compliance/{docId} { allow read, write: if request.auth != null; }
    match /wash_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Laundry (Laundromats) — prefix: laundry_ ──
    match /laundry_machines/{docId} { allow read, write: if request.auth != null; }
    match /laundry_locations/{docId} { allow read, write: if request.auth != null; }
    match /laundry_incidents/{docId} { allow read, write: if request.auth != null; }
    match /laundry_patrols/{docId} { allow read, write: if request.auth != null; }
    match /laundry_signals/{docId} { allow read, write: if request.auth != null; }

    // ── Brew (Breweries & Wineries) — prefix: brew_ ──
    match /brew_vessels/{docId} { allow read, write: if request.auth != null; }
    match /brew_batches/{docId} { allow read, write: if request.auth != null; }
    match /brew_readings/{docId} { allow read, write: if request.auth != null; }
    match /brew_equipment/{docId} { allow read, write: if request.auth != null; }
    match /brew_signals/{docId} { allow read, write: if request.auth != null; }

    // ── PT (WebPT EMR replica) — prefix: pt_ ──
    // Shared, public, fabricated demo data (no PHI). The /pt app now supports
    // Google / email sign-in, but it also offers a no-account "demo mode" that
    // reads this shared data, so reads stay open. Writes stay open so the
    // client-side seed script (scripts/seed-firestore.mjs) can populate it.
    match /pt_patients/{docId} { allow read, write: if true; }
    match /pt_therapists/{docId} { allow read, write: if true; }
    match /pt_appointments/{docId} { allow read, write: if true; }
    match /pt_documents/{docId} { allow read, write: if true; }
    match /pt_claims/{docId} { allow read, write: if true; }
    match /pt_exercises/{docId} { allow read, write: if true; }
    match /pt_meta/{docId} { allow read, write: if true; }

    // Per-user PRIVATE space for signed-in /pt users. Everything under a user's
    // own uid is readable/writable only by that authenticated account, so one
    // user can never see or modify another user's data.
    match /pt_users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Fit (Bodymind / Mindbody studio replica) — prefix: fit_ ──
    // Public demo: the /fit app offers a no-account "demo mode" that reads and
    // writes a single shared sample document. Reads/writes stay open so the
    // client can seed-on-empty and persist demo edits (no real data here).
    match /fit_store/{docId} { allow read, write: if true; }

    // Per-user PRIVATE space for signed-in /fit users. Everything under a
    // user's own uid is readable/writable only by that authenticated account,
    // so one studio owner can never see or modify another's data. The app
    // stores each account's studio at fit_users/{uid}/store/data.
    match /fit_users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Coach (Everfit coaching-platform replica) — prefix: coach_ ──
    // Deployed at palmr.ai/coach. Uses its OWN prefix (not fit_, which the
    // mindbody studio replica above already owns). Shared, public, fabricated
    // demo data (no real client PHI): the /coach app offers a no-account "demo
    // mode" that reads this shared data, so reads stay open; writes stay open so
    // the client-side seed script can populate it.
    match /coach_clients/{docId} { allow read, write: if true; }
    match /coach_exercises/{docId} { allow read, write: if true; }
    match /coach_workouts/{docId} { allow read, write: if true; }
    match /coach_programs/{docId} { allow read, write: if true; }
    match /coach_schedule/{docId} { allow read, write: if true; }
    match /coach_autoflows/{docId} { allow read, write: if true; }
    match /coach_tasks/{docId} { allow read, write: if true; }
    match /coach_forms/{docId} { allow read, write: if true; }
    match /coach_packages/{docId} { allow read, write: if true; }
    match /coach_mealplans/{docId} { allow read, write: if true; }
    match /coach_conversations/{docId} { allow read, write: if true; }
    match /coach_events/{docId} { allow read, write: if true; }
    match /coach_meta/{docId} { allow read, write: if true; }

    // Per-user PRIVATE space for signed-in /coach users. Everything under a
    // coach's own uid is readable/writable only by that authenticated account,
    // so one coach can never see or modify another coach's client roster.
    match /coach_users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // The gym's published weekly class grid, read by the Palmr coach app's
    // Schedule tab. It is a mirror of the recorders' own wallcam_schedule.json,
    // published by a service account (palmr-coach-ios/scripts/publish-class-
    // schedule.cjs), which bypasses rules — so client writes stay closed. Reads
    // are open like scan_results above: a gym class timetable is public info and
    // the app renders the tab before sign-in.
    match /coach_class_schedules/{gymId} {
      allow read: if true;
      allow write: if false;
    }

    // A user's class subscription: which scheduled classes should have their
    // recording auto-delivered to them. Doc id IS the subscriber's auth uid, so
    // a user can only ever read or write their own picks. The delivery watcher
    // (commander/worker/class-video-watcher.mjs) enumerates every subscriber
    // with the admin SDK, which bypasses these rules.
    match /coach_schedule_subscriptions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // palmr.ai/scan — daily Qullamaggie breakout scan output. Read-open so
    // the static UI can fetch without auth; writes only via the service
    // account (firebase-admin in scripts/daily_scan.py from a cron on
    // mac-mini), which bypasses rules.
    match /scan_results/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /scan_results/by_date/days/{day} {
      allow read: if true;
      allow write: if false;
    }

    // palmr.ai/scan OTA tab — supply/demand zone scan; same access pattern
    // as scan_results (public read, service-account writes from mac-mini cron).
    match /ota_scan_results/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /ota_scan_results/by_date/days/{day} {
      allow read: if true;
      allow write: if false;
    }
  
    // ══════════════════════════════════════════════════════════════════
    // RESTORED 2026-07-19 (#1069) — these blocks were dropped when another
    // repo deployed its own firestore.rules to this shared project on
    // 2026-07-19T03:43Z, replacing the whole ruleset. Their absence made
    // every read fall through to deny (the iOS Videos tab showed
    // "Missing or insufficient permissions"). Source of truth:
    // ~/repos/experimental/commander/firestore.rules
    // ══════════════════════════════════════════════════════════════════

    function isAdminUser() {
      let userDoc = get(/databases/$(database)/documents/commander_user_projects/$(request.auth.uid));
      return userDoc != null && userDoc.data.isAdmin == true;
    }
    function mirrorsAllowed() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/mirrors_allowed_users/$(request.auth.token.email));
    }

    match /mirror_sessions/{sessionId} {
      allow read, write: if request.auth != null;
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
    match /mirrors_sessions/{sessionId} {
      allow read: if mirrorsAllowed();
      // Recorder creates + writes frames (merge); viewers write solveRequest
      // (merge). Neither may set or change aiSolution (backend-only).
      allow create: if mirrorsAllowed()
        && !('aiSolution' in request.resource.data);
      allow update: if mirrorsAllowed()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['aiSolution']);
      allow delete: if mirrorsAllowed();
    }
    match /mirrors_allowed_users/{email} {
      // A signed-in user may check their own membership; the list is managed by
      // an admin (Firestore console / firebase-admin SDK) only.
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }
    match /wallcam_highlights/{sessionId} {
      allow read, write: if true;
    }
    match /experimental_videos/{id} {
      allow read: if request.auth != null;
    }
    match /released_recordings/{id} {
      allow read, write: if request.auth != null;
    }
    match /dan_3d_map_requests/{id}   { allow read, write: if request.auth != null; }
    match /dan_analysis_requests/{id} { allow read, write: if request.auth != null; }
    match /dan_3d_map/{id}            { allow read: if request.auth != null; }
    match /dan_analysis/{id}          { allow read: if request.auth != null; }
    match /issue_reports/{docId}      { allow read, create: if request.auth != null; }
    match /pool_analyses/{id} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdminUser();
    }
    match /commander_class_deliveries/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /commander_videos/{videoId} {
      allow read, write: if request.auth != null;
    }
    match /manage_allowed_users/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /commander_presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /commander_channels/{channelId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }
    match /commander_weekly_summaries/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /commander_project_members/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /test_runs/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /orrat_calls/{callId}        { allow read, write: if request.auth != null; }
    match /orrat_menu/{docId}          { allow read, write: if request.auth != null; }
    match /orrat_settings/{docId}      { allow read, write: if request.auth != null; }
}
}
