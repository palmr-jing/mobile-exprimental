rules_version = '2';
// Storage rules for the emulator (and a proposed production baseline — the
// commander repo currently ships NO storage rules; adding this there is a
// flagged follow-up). Authenticated users may read/write chat attachments.
service firebase.storage {
  match /b/{bucket}/o {
    match /chat-uploads/{channelId}/{fileName=**} {
      allow read, write: if request.auth != null;
    }
  }
}
